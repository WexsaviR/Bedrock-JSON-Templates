{
  "format_version": "1.21.0",
  "minecraft:entity": {
    "description": {
      "identifier": "your_namespace:simple_entity",
      "is_spawnable": true,
      "is_summonable": true,
      "is_experimental": false
    },
    "components": {
      "minecraft:physics": {
        "has_gravity": true,
        "has_collision": true
      },
      "minecraft:collision_box": {
        "width": 0.6,
        "height": 1.8
      },
      "minecraft:health": {
        "value": 20,
        "max": 20
      },
      "minecraft:movement": {
        "value": 0.25
      },
      "minecraft:nameable": {
        "allow_name_tag_renaming": true,
        "always_show": true
      },
      "minecraft:despawn": {
        "despawn_from_distance": {
          "min_distance": 128,
          "max_distance": 256
        }
      }
    }
  }
}