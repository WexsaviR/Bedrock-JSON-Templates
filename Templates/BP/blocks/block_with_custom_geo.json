{
  "format_version": "1.21.0",
  "minecraft:block": {
    "description": {
      "identifier": "your_namespace:block_with_custom_geo",
      "menu_category": {
        "category": "nature"
      },
      "traits": {
        "minecraft:placement_direction": {
          "enabled_states": ["minecraft:cardinal_direction"]
        }
      }
    },
    "components": {
      "minecraft:destructible_by_mining": {
        "seconds_to_destroy": 0.3
      },
      "minecraft:map_color": "#FFFFFF",
      "minecraft:destructible_by_explosion": {
        "explosion_resistance": 1
      },
      "minecraft:flammable": {
        "flame_odds": 1,
        "burn_odds": 1
      },
      "minecraft:light_dampening": 0,
      "minecraft:light_emission": 0,
      "minecraft:material_instances": {
        "*": {
          "texture": "your_texture",
          "render_method": "alpha_test"
        }
      },
      "minecraft:geometry": "geometry.your_geometry",
      "minecraft:collision_box": {
        "origin": [-8, 0, -8],
        "size": [16, 16, 16]
      },
      "minecraft:selection_box": {
        "origin": [-8, 0, -8],
        "size": [16, 16, 16]
      },
      "minecraft:loot": "loot_tables/your_loot_table.json" // If loot_table is not needed, then you need to write empty.json or delete this str
    },
    "permutations": [
      {
        "condition": "q.block_state('minecraft:cardinal_direction') == 'north'",
        "components": {
          "minecraft:transformation": {
            "rotation": [0, 0, 0]
          }
        }
      },
      {
        "condition": "q.block_state('minecraft:cardinal_direction') == 'south'",
        "components": {
          "minecraft:transformation": {
            "rotation": [0, 180, 0]
          }
        }
      },
      {
        "condition": "q.block_state('minecraft:cardinal_direction') == 'east'",
        "components": {
          "minecraft:transformation": {
            "rotation": [0, 90, 0]
          }
        }
      },
      {
        "condition": "q.block_state('minecraft:cardinal_direction') == 'west'",
        "components": {
          "minecraft:transformation": {
            "rotation": [0, 270, 0]
          }
        }
      }
    ]
  }
}